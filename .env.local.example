NEXT_PUBLIC_THEME=nounish

# Snapie Auth — custodial account gateway (https://auth.snapie.io)
# Dev: http://localhost:3500  |  Prod: https://auth.snapie.io
SNAPIE_AUTH_URL=http://localhost:3500
# Server-side key for /api/internal/* calls (sponsor tokens, provisioning)
SNAPIE_AUTH_INTERNAL_KEY=
NEXT_PUBLIC_HIVE_COMMUNITY_TAG=hive-167980
NEXT_PUBLIC_HIVE_SEARCH_TAG=hive-167980
NEXT_PUBLIC_HIVE_USER=skatedev
HIVE_POSTING_KEY=posting_private_key_here_
# Optional server-side account utilities (only if using account-create helpers)
# ACCOUNT_CREATOR=your_creator_account
# ACCOUNT_KEY=your_creator_private_key
# Account that receives posting authority on every new account created via the faucet or sponsor flow.
# Defaults to 'snapie' if not set.
NEXT_PUBLIC_POSTING_AUTHORITY_ACCOUNT=snapie
NEXT_PUBLIC_DISPLAY_CURRENCY=
NEXT_PUBLIC_HIVESIGNER_ENABLED=false
NEXT_PUBLIC_3SPEAK_API_KEY=your_3speak_api_key_here
NEXT_PUBLIC_IMAGE_SERVER_API_KEY=<api key goes here>
NEXT_PUBLIC_GIPHY_API_KEY=qXGQXTPKyNJByTFZpW7Kb0tEFeB90faV
# Legacy/fallback key name still referenced in one composer path:
# GIPHY_API_KEY=qXGQXTPKyNJByTFZpW7Kb0tEFeB90faV

# Hangouts (OpenPods) API + LiveKit
NEXT_PUBLIC_HANGOUTS_API_URL=https://hangout-api.3speak.tv
NEXT_PUBLIC_LIVEKIT_URL=wss://livekit.3speak.tv
# Where to persist the hangouts session JWT. Default 'none' (re-sign every
# visit). 'session' survives reloads in the same tab. 'local' survives browser
# restarts but is XSS-readable for up to the JWT TTL (~24h).
NEXT_PUBLIC_HANGOUTS_TOKEN_STORAGE=none

# Hive Chat
MONGODB_URI=mongodb://user:pass@host:27017/dbname?authSource=admin
MONGODB_DB_NAME=snapiechat
CHAT_JWT_SECRET=<random-secret-min-32-chars>
# Firebase Cloud Messaging (optional — chat works without push notifications)
# Encode your Firebase service account JSON: base64 -w0 service-account.json
FIREBASE_SERVICE_ACCOUNT=<base64-encoded-firebase-service-account-json>
NEXT_PUBLIC_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","messagingSenderId":"...","appId":"..."}
NEXT_PUBLIC_FIREBASE_VAPID_KEY=<firebase-web-push-vapid-key>
NEXT_PUBLIC_CHAT_DEFAULT_CHANNEL=general

# Translation (LibreTranslate — self-hosted or public instance)
# Self-hosted on same server: http://localhost:5000
# External instance: https://translate.yourdomain.com
# Leave blank to disable the translate button entirely.
LIBRETRANSLATE_URL=http://localhost:5000
LIBRETRANSLATE_KEY=

# available themes -> bluesky, hacker, forest, cannabis, mengao, nounish, hivebr, windows95
# available currencies -> BRL, EUR, GBP, JPY, AUD, CAD, CHF, CNY, INR (leave empty for HBD/USD)
# Get 3Speak API key from https://embed.3speak.tv/ for video upload functionality
# Get Image Server API key from images.3speak.tv for fallback image uploads